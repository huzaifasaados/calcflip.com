// generate time-conversions.json
const data = [];
for (let h = 0; h < 24; h++) {
  for (let m = 0; m < 60; m++) {
    const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
    const period = h < 12 ? 'AM' : 'PM';
    const time24 = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
    const military = `${String(h).padStart(2,'0')}${String(m).padStart(2,'0')}`;
    data.push({ time_24h: time24, time_12h: `${h12}:${String(m).padStart(2,'0')} ${period}`, military, period, url: `https://calcflip.com/time/${String(h).padStart(2,'0')}-${String(m).padStart(2,'0')}` });
  }
}
console.log(JSON.stringify({ total: 1440, conversions: data }, null, 2));
